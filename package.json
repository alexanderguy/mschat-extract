{
  "name": "mschat-extractor",
  "version": "1.0.0",
  "description": "Graphics extraction toolkit for Microsoft Chat 2.5",
  "type": "module",
  "scripts": {
    "format": "prettier --write '**/*.{ts,md,json}'",
    "format:check": "prettier --check '**/*.{ts,md,json}'",
